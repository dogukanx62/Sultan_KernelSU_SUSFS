+#ifdef CONFIG_COMPAT
+void zeromount_inject_compat_dents(struct file *file, void __user **dirent,
+				   int *count, loff_t *pos)
+{
+	zeromount_inject_dents_common(file, dirent, count, pos,
+				       ZM_DIRENT_COMPAT);
+}
+#endif
