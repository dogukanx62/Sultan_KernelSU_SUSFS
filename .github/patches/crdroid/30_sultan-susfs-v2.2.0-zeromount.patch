+static void zeromount_free_rule_rcu(struct rcu_head *head)
+{
+	struct zeromount_rule *rule = container_of(head, struct zeromount_rule, rcu);
+
+	kfree(rule->virtual_path);
+	kfree(rule->real_path);
+	kfree(rule);
