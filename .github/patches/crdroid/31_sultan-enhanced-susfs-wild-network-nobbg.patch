+#ifdef CONFIG_KSU_SUSFS_UNICODE_FILTER
+static bool susfs_has_suspicious_unicode(const unsigned char *path, size_t len)
+{
+	size_t i = 0;
+
+	while (i < len && path[i]) {
+		unsigned char c = path[i];
+
+		if (likely(c < 0x80)) {
+			i++;
+			continue;
+		}
+
+		if (c == 0xc2 && i + 1 < len && path[i + 1] == 0xad)
+			return true;
+		if (c == 0xcd && i + 1 < len && path[i + 1] == 0x8f)
+			return true;
+		if (c == 0xd8 && i + 1 < len && path[i + 1] == 0x9c)
+			return true;
+
+		if (c == 0xe1 && i + 2 < len) {
+			if (path[i + 1] == 0x85 &&
+			    (path[i + 2] == 0x9f || path[i + 2] == 0xa0))
+				return true;
+			if (path[i + 1] == 0x9e &&
+			    (path[i + 2] == 0xb4 || path[i + 2] == 0xb5))
+				return true;
+			if (path[i + 1] == 0xa0 &&
+			    path[i + 2] >= 0x8b && path[i + 2] <= 0x8e)
+				return true;
+		}
+
+		if (c == 0xe2 && i + 2 < len) {
+			if (path[i + 1] == 0x80 &&
+			    path[i + 2] >= 0x8a && path[i + 2] <= 0x8f)
+				return true;
+			if (path[i + 1] == 0x80 &&
+			    path[i + 2] >= 0xaa && path[i + 2] <= 0xae)
+				return true;
+			if (path[i + 1] == 0x81 &&
+			    path[i + 2] >= 0xa0 && path[i + 2] <= 0xaf)
+				return true;
+		}
+
+		if (c == 0xe3 && i + 2 < len &&
+		    path[i + 1] == 0x85 && path[i + 2] == 0xa4)
+			return true;
+
+		if (c == 0xef && i + 2 < len) {
+			if (path[i + 1] == 0xbb && path[i + 2] == 0xbf)
+				return true;
+			if (path[i + 1] == 0xb8 &&
+			    path[i + 2] >= 0x80 && path[i + 2] <= 0x8f)
+				return true;
+			if (path[i + 1] == 0xbe && path[i + 2] == 0xa0)
+				return true;
+			if (path[i + 1] == 0xbf &&
+			    path[i + 2] >= 0xb0 && path[i + 2] <= 0xb8)
+				return true;
+		}
+
+		/* Invalid or truncated UTF-8 is left to the filesystem. */
+		if (c < 0xe0 && i + 1 < len)
+			i += 2;
+		else if (c < 0xf0 && i + 2 < len)
+			i += 3;
+		else if (i + 3 < len)
+			i += 4;
+		else
+			i++;
+	}
+
+	return false;
+}
+
+bool susfs_check_unicode_filename(const struct filename *filename)
+{
+	size_t len;
+
+	if (!filename || IS_ERR(filename) || !filename->name)
+		return false;
+	if (current_uid().val == 0 || current_uid().val == 1000)
+		return false;
+
+	len = strnlen(filename->name, PATH_MAX);
+	return susfs_has_suspicious_unicode((const unsigned char *)filename->name,
+						     len);
+}
+
+bool susfs_check_unicode_user(const char __user *filename)
+{
+	struct filename *name;
+	bool blocked;
+
+	if (!filename || current_uid().val == 0 || current_uid().val == 1000)
+		return false;
+
+	name = getname(filename);
+	if (IS_ERR(name))
+		return false;
+	blocked = susfs_check_unicode_filename(name);
+	putname(name);
+	return blocked;
+}
+#endif /* CONFIG_KSU_SUSFS_UNICODE_FILTER */
