+#ifdef CONFIG_KSU_SUSFS_HIDDEN_NAME
+struct susfs_hidden_name_entry {
+	char name[SUSFS_MAX_LEN_PATHNAME];
+	unsigned int namelen;
+	uid_t owner_uid;
+	struct hlist_node node;
+};
+
+static DEFINE_HASHTABLE(susfs_hidden_names, 8);
+static DEFINE_SPINLOCK(susfs_hidden_names_lock);
+
+static u32 susfs_hidden_name_hash(const char *name, unsigned int namelen)
+{
+	u32 hash = 0;
+	unsigned int i;
+
+	for (i = 0; i < namelen; i++)
+		hash = hash * 31 + (unsigned char)name[i];
+	return hash;
+}
+
+static bool susfs_is_hidden_name(const char *name, unsigned int namelen,
+				 uid_t caller_uid)
+{
+	struct susfs_hidden_name_entry *entry;
+	u32 key;
+
+	if (!name || !namelen || !caller_uid)
+		return false;
+
+	key = susfs_hidden_name_hash(name, namelen);
+	rcu_read_lock();
+	hash_for_each_possible_rcu(susfs_hidden_names, entry, node, key) {
+		if (entry->namelen != namelen ||
+		    memcmp(entry->name, name, namelen))
+			continue;
+		if (READ_ONCE(entry->owner_uid) &&
+		    caller_uid == READ_ONCE(entry->owner_uid)) {
+			rcu_read_unlock();
+			return false;
+		}
+		rcu_read_unlock();
+		return true;
+	}
+	rcu_read_unlock();
+	return false;
+}
+
+static void susfs_add_hidden_name(const char *name, unsigned int namelen,
+				  uid_t owner_uid)
+{
+	struct susfs_hidden_name_entry *entry;
+	struct susfs_hidden_name_entry *new_entry;
+	u32 key;
+
+	if (!name || !namelen || namelen >= SUSFS_MAX_LEN_PATHNAME)
+		return;
+
+	new_entry = kzalloc(sizeof(*new_entry), GFP_KERNEL);
+	if (!new_entry)
+		return;
+	memcpy(new_entry->name, name, namelen);
+	new_entry->namelen = namelen;
+	new_entry->owner_uid = owner_uid;
+	key = susfs_hidden_name_hash(name, namelen);
+
+	spin_lock(&susfs_hidden_names_lock);
+	hash_for_each_possible(susfs_hidden_names, entry, node, key) {
+		if (entry->namelen == namelen &&
+		    !memcmp(entry->name, name, namelen)) {
+			if (!READ_ONCE(entry->owner_uid) && owner_uid)
+				WRITE_ONCE(entry->owner_uid, owner_uid);
+			spin_unlock(&susfs_hidden_names_lock);
+			kfree(new_entry);
+			return;
+		}
+	}
+	hash_add_rcu(susfs_hidden_names, &new_entry->node, key);
+	spin_unlock(&susfs_hidden_names_lock);
+}
+
+static void susfs_try_register_hidden_name(const char *pathname)
+{
+	const char *basename;
+	const char *prefix;
+	char *data_pathname;
+	struct path data_path;
+	unsigned int namelen = 0;
+	uid_t owner_uid = 0;
+
+	prefix = strstr(pathname, "/Android/data/");
+	if (prefix)
+		basename = prefix + strlen("/Android/data/");
+	else {
+		prefix = strstr(pathname, "/Android/obb/");
+		if (!prefix)
+			return;
+		basename = prefix + strlen("/Android/obb/");
+	}
+
+	while (basename[namelen] && basename[namelen] != '/' &&
+	       namelen < SUSFS_MAX_LEN_PATHNAME)
+		namelen++;
+	if (!namelen || namelen >= SUSFS_MAX_LEN_PATHNAME)
+		return;
+	if (basename[0] == '.' &&
+	    (namelen == 1 || (namelen == 2 && basename[1] == '.')))
+		return;
+
+	data_pathname = kasprintf(GFP_KERNEL, "/data/data/%.*s", namelen,
+				   basename);
+	if (data_pathname) {
+		if (!kern_path(data_pathname, LOOKUP_FOLLOW, &data_path)) {
+			struct inode *inode = d_backing_inode(data_path.dentry);
+
+			if (inode)
+				owner_uid = inode->i_uid.val;
+			path_put(&data_path);
+		}
+		kfree(data_pathname);
+	}
+
+	susfs_add_hidden_name(basename, namelen, owner_uid);
+}
+
+bool susfs_is_hidden_android_data_dentry(const struct dentry *dentry,
+						 uid_t caller_uid)
+{
+	const struct dentry *parent;
+	const struct dentry *grandparent;
+
+	if (!dentry || caller_uid < 10000 ||
+	    !susfs_is_current_proc_umounted_app())
+		return false;
+
+	parent = dentry->d_parent;
+	if (!parent || parent == dentry)
+		return false;
+	grandparent = parent->d_parent;
+	if (!grandparent || grandparent == parent)
+		return false;
+
+	if (!((parent->d_name.len == 4 &&
+	       !memcmp(parent->d_name.name, "data", 4)) ||
+	      (parent->d_name.len == 3 &&
+	       !memcmp(parent->d_name.name, "obb", 3))))
+		return false;
+	if (grandparent->d_name.len != 7 ||
+	    memcmp(grandparent->d_name.name, "Android", 7))
+		return false;
+
+	return susfs_is_hidden_name(dentry->d_name.name, dentry->d_name.len,
+				    caller_uid);
+}
