diff --git a/security/baseband-guard/tracing/tracing.c b/security/baseband-guard/tracing/tracing.c
new file mode 100644
index 0000000000000000000000000000000000000000..eabe566f05947093bee3014e3c9574c47ed8a1c5
--- /dev/null
+++ b/security/baseband-guard/tracing/tracing.c
@@ -0,0 +1,51 @@
+// SPDX-License-Identifier: GPL-2.0
+
+#include <linux/cred.h>
+#include <linux/errno.h>
+
+#include "tracing.h"
+
+#ifdef BBG_USE_DEFINE_LSM
+struct lsm_blob_sizes bbg_blob_sizes __ro_after_init = {
+	.lbs_cred = sizeof(struct bbg_cred_security_struct),
+};
+#endif
+
+int bb_cred_prepare(struct cred *new, const struct cred *old, gfp_t gfp)
+{
+	const struct bbg_cred_security_struct *old_tsec = bbg_cred(old);
+	struct bbg_cred_security_struct *new_tsec = bbg_cred(new);
+
+	if (new_tsec)
+		new_tsec->is_untrusted_process =
+			old_tsec ? old_tsec->is_untrusted_process : 0;
+	return 0;
+}
+
+void bb_cred_transfer(struct cred *new, const struct cred *old)
+{
+	const struct bbg_cred_security_struct *old_tsec = bbg_cred(old);
+	struct bbg_cred_security_struct *new_tsec = bbg_cred(new);
+
+	if (new_tsec)
+		new_tsec->is_untrusted_process =
+			old_tsec ? old_tsec->is_untrusted_process : 0;
+}
+
+void bbg_mark_cred_untrusted(struct cred *cred)
+{
+	struct bbg_cred_security_struct *bbg_tsec = bbg_cred(cred);
+
+	if (bbg_tsec)
+		bbg_tsec->is_untrusted_process = 1;
+}
+
+int __maybe_unused bbg_process_setpermissive(void)
+{
+	return 0;
+}
+
+int __maybe_unused bbg_test_domain_transition(u32 target_secid)
+{
+	return 0;
+}
diff --git a/security/baseband-guard/tracing/tracing.h b/security/baseband-guard/tracing/tracing.h
new file mode 100644
index 0000000000000000000000000000000000000000..726532e754153acd0551df73e001fbe3f14617ed
--- /dev/null
+++ b/security/baseband-guard/tracing/tracing.h
@@ -0,0 +1,37 @@
+#ifndef _BBG_TRACING_H_
+#define _BBG_TRACING_H_
+
+#include <linux/cred.h>
+#include <linux/lsm_hooks.h>
+
+struct bbg_cred_security_struct {
+	u8 is_untrusted_process;	/* credential was granted root by KernelSU */
+};
+
+#ifdef BBG_USE_DEFINE_LSM
+extern struct lsm_blob_sizes bbg_blob_sizes;
+
+static __maybe_unused inline struct bbg_cred_security_struct *bbg_cred(const struct cred *cred)
+{
+	if (unlikely(!cred || !cred->security))
+		return NULL;
+
+	return (struct bbg_cred_security_struct *)
+		((char *)cred->security + bbg_blob_sizes.lbs_cred);
+}
+
+#else
+struct bbg_cred_security_struct* bbg_cred(const struct cred *cred);
+#endif
+
+static __maybe_unused inline bool current_process_trusted(void)
+{
+	const struct bbg_cred_security_struct *bbg_tsec;
+
+	bbg_tsec = bbg_cred(current_cred());
+	return !bbg_tsec || !bbg_tsec->is_untrusted_process;
+}
+
+void bbg_mark_cred_untrusted(struct cred *cred);
+
+#endif
